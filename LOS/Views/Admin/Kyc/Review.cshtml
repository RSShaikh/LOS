@model LOS.Models.Customer
@{
    Layout = "~/Views/Shared/_LoanOfficerLayout.cshtml";
    ViewBag.PageTitle = "KYC Review";

    var docs = Model.KYCDocument?
                    .Where(d => d.IsActive)
                    .OrderByDescending(d => d.UploadDate)
                    .ToList()
               ?? new List<LOS.Models.KYCDocument>();

    int approved = docs.Count(d => d.VerificationStatus == "Approved");
    string overallStatus = "No Documents"; string overallBadge = "secondary";
    if (docs.Any())
    {
        if (docs.Any(d => d.VerificationStatus == "Rejected")) { overallStatus = "Has Rejections"; overallBadge = "danger"; }
        else if (docs.Any(d => d.VerificationStatus == "Pending")) { overallStatus = "Pending Review"; overallBadge = "warning"; }
        else { overallStatus = "Fully Approved"; overallBadge = "success"; }
    }
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">

    <div class="mb-3">
        <a asp-action="Index" asp-controller="AdminKyc" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i>Back to KYC List
        </a>
    </div>

    @* Customer Info *@
    <div class="card shadow-lg mb-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Customer Info — @Model.FirstName @Model.LastName
                <span class="badge bg-@overallBadge ms-2">@overallStatus</span>
            </h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Customer Code</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>PAN</th>
                        <th>Aadhaar</th>
                        <th>Employment</th>
                        <th>Monthly Income</th>
                        <th>Docs Approved</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.CustomerCode</td>
                        <td>@Model.Email</td>
                        <td>@(Model.Mobile ?? "—")</td>
                        <td>@(Model.PAN ?? "—")</td>
                        <td>@(Model.AadhaarNo ?? "—")</td>
                        <td>@(Model.EmploymentType ?? "—")</td>
                        <td>@(Model.MonthlyIncome.HasValue ? "₹" + Model.MonthlyIncome.Value.ToString("N0") : "—")</td>
                        <td>@approved / 4</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    @* Documents Table *@
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Uploaded Documents (@docs.Count)</h5>
        </div>
        <div class="card-body p-0">
            @if (!docs.Any())
            {
                <p class="text-muted text-center py-5">No documents uploaded yet.</p>
            }
            else
            {
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Document Type</th>
                            <th>File Name</th>
                            <th>Uploaded On</th>
                            <th>Preview</th>
                            <th>Status</th>
                            <th>Reject Reason</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in docs)
                        {
                            var isImage = new[] { ".jpg", ".jpeg", ".png" }
                                .Contains(System.IO.Path.GetExtension(doc.FilePath ?? "").ToLower());
                            var color = doc.VerificationStatus == "Approved" ? "success"
                                      : doc.VerificationStatus == "Rejected" ? "danger" : "warning";
                            <tr>
                                <td class="ps-3"><strong>@doc.DocumentType</strong></td>
                                <td class="small text-muted">@doc.FileName</td>
                                <td class="small">@doc.UploadDate.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    @if (isImage)
                                    {
                                        <img src="@doc.FilePath"
                                             style="height:36px;width:46px;object-fit:cover;border-radius:4px;cursor:pointer;border:1px solid #ccc;"
                                             onclick="window.open('@doc.FilePath','_blank')" title="Click to view" />
                                    }
                                    else
                                    {
                                        <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-danger">
                                            <i class="fa-solid fa-file-pdf me-1"></i>PDF
                                        </a>
                                    }
                                </td>
                                <td><span class="badge bg-@color">@doc.VerificationStatus</span></td>
                                <td class="small text-danger">
                                    @if (!string.IsNullOrEmpty(doc.RejectReason)) { @doc.RejectReason }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-secondary" title="View">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (doc.VerificationStatus != "Approved")
                                        {
                                            <form asp-action="ApproveDocument" asp-controller="AdminKyc" method="post" class="d-inline">
                                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                                <input type="hidden" name="customerId" value="@Model.CustomerId" />
                                                <button class="btn btn-sm btn-success" title="Approve">
                                                    <i class="fa-solid fa-check"></i> Approve
                                                </button>
                                            </form>
                                        }
                                        @if (doc.VerificationStatus != "Rejected")
                                        {
                                            <button class="btn btn-sm btn-danger" title="Reject"
                                                    onclick="showRejectModal(@doc.DocumentId, @Model.CustomerId)">
                                                <i class="fa-solid fa-xmark"></i> Reject
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@* Reject Modal *@
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold">Reject Document</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RejectDocument" asp-controller="AdminKyc" method="post">
                <div class="modal-body">
                    <input type="hidden" name="documentId" id="rejectDocId" />
                    <input type="hidden" name="customerId" id="rejectCustId" />
                    <label class="form-label small fw-semibold">Reason for Rejection</label>
                    <textarea class="form-control" name="rejectReason" rows="3"
                              placeholder="e.g. Document is blurry, PAN not visible..." required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function showRejectModal(docId, custId) {
        document.getElementById('rejectDocId').value = docId;
        document.getElementById('rejectCustId').value = custId;
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }
</script>
}
