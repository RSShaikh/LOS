@model LOS.Models.RegisterViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow p-4">
                <h2 class="text-center mb-4">Customer Registration</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>First Name</label>
                            <input asp-for="FirstName" class="form-control" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Last Name</label>
                            <input asp-for="LastName" class="form-control" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Email</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Mobile No</label>
                            <input asp-for="Mobile" class="form-control"
                                   inputmode="numeric" maxlength="10"
                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                            <span asp-validation-for="Mobile" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>PAN Number</label>
                            <input asp-for="PAN" class="form-control"
                                   maxlength="10"
                                   oninput="this.value=this.value.toUpperCase()" />
                            <span asp-validation-for="PAN" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Aadhaar Number</label>
                            <input asp-for="AadhaarNo" class="form-control"
                                   inputmode="numeric" maxlength="12"
                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                            <span asp-validation-for="AadhaarNo" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Age</label>
                            <input asp-for="Age" class="form-control" type="number"
                                   onblur="if(this.value && this.value<18)this.value=18; if(this.value>60)this.value=60;" />
                            <span asp-validation-for="Age" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Employment Type</label>
                            <select asp-for="EmploymentType" class="form-select">
                                <option value="">— Select —</option>
                                <option>Salaried</option>
                                <option>Self-Employed</option>
                                <option>Business</option>
                                <option>Other</option>
                            </select>
                            <span asp-validation-for="EmploymentType" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Monthly Income (₹)</label>
                            <input asp-for="MonthlyIncome" class="form-control"
                                   inputmode="numeric"
                                   oninput="this.value=this.value.replace(/[^0-9]/g,'')" />
                            <span asp-validation-for="MonthlyIncome" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Password</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                    </div>

                    <button class="btn btn-dark w-100">Register</button>

                    <div class="text-center mt-3">
                        <a href="/Auth/Login">Already have an account?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}