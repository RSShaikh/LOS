@model LOS.Models.EligibilityResult

<div class="container mt-5">
    <div class="card shadow p-4">
        <h3 class="text-danger">Reject Eligibility</h3>
        <form method="post">
            <input type="hidden" asp-for="EligibilityId" />
            <div class="mb-3">
                <label class="form-label fw-bold">Enter Rejection Reason</label>
                <textarea asp-for="RejectionReason"
                          class="form-control"
                          rows="5"
                          required></textarea>
            </div>
            <button type="submit" class="btn btn-danger">Submit Reason</button>
            <a asp-action="EIndex" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
