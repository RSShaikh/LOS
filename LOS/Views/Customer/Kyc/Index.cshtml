@model LOS.Models.Customer
@{
    Layout = "~/Views/Shared/_LoanLayout.cshtml";
    ViewBag.PageTitle = "My KYC Documents";

    var activeDocs = Model.KYCDocument?
        .Where(d => d.IsActive)
        .OrderByDescending(d => d.UploadDate)
        .ToList() ?? new List<LOS.Models.KYCDocument>();

    var rejectedDocs = activeDocs.Where(d => d.VerificationStatus == "Rejected").ToList();
    var requiredTypes = new[] { "Aadhaar Card", "PAN Card", "Salary Slip", "Profile Photo" };
}

@if (TempData["KycSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        @TempData["KycSuccess"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        @TempData["Error"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@foreach (var rej in rejectedDocs)
{
    <div class="alert alert-danger alert-dismissible fade show mb-2" role="alert">
        <strong>@rej.DocumentType Rejected</strong>
        @if (!string.IsNullOrEmpty(rej.RejectReason)) { <span> — @rej.RejectReason</span> }
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid px-0">

    @* TOP — Upload Document *@
    <div class="card shadow-lg mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Upload Document</h5>
        </div>
        <div class="card-body">
            <form asp-action="Upload" asp-controller="CustomerKyc"
                  method="post" enctype="multipart/form-data" id="uploadForm">
                <div class="row align-items-end g-3">
                    <div class="col-md-4">
                        <label class="form-label">Document Type</label>
                        <select class="form-select" name="documentType" id="docTypeSelect"
                                onchange="showFileInput(this.value)" required>
                            <option value="">— Select Type —</option>
                            @foreach (var type in requiredTypes)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-5" id="fileSection" style="display:none;">
                        <label class="form-label">Select File</label>
                        <input type="file" class="form-control" name="file"
                               id="fileInput" accept=".jpg,.jpeg,.png,.pdf"
                               onchange="previewFile(this)" required />
                        <div class="form-text">JPG, PNG or PDF · Max 5MB</div>
                    </div>

                    <div class="col-md-3" id="submitSection" style="display:none;">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fa-solid fa-cloud-arrow-up me-2"></i>Upload
                        </button>
                    </div>
                </div>

                <div id="previewSection" style="display:none;" class="mt-3 text-center">
                    <img id="imgPreview" style="max-height:100px;border-radius:6px;border:1px solid #dee2e6;display:none;" />
                    <div id="pdfPreview" style="display:none;" class="p-3 bg-light rounded d-inline-block">
                        <i class="fa-solid fa-file-pdf text-danger fs-3"></i>
                        <div class="small mt-1" id="pdfName"></div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* BOTTOM — My Documents Table *@
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">My Documents</h5>
        </div>
        <div class="card-body p-0">
            @if (!activeDocs.Any())
            {
                <p class="text-muted text-center py-5">No documents uploaded yet.</p>
            }
            else
            {
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Document Type</th>
                            <th>File Name</th>
                            <th>Uploaded On</th>
                            <th>Status</th>
                            <th>Reject Reason</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in activeDocs)
                        {
                            <tr>
                                <td class="ps-3"><strong>@doc.DocumentType</strong></td>
                                <td class="small text-muted">@doc.FileName</td>
                                <td class="small">@doc.UploadDate.ToString("dd-MMM-yyyy")</td>
                                <td>
                                    @if (doc.VerificationStatus == "Approved")
                                    { <span class="badge bg-success">Approved</span> }
                                    else if (doc.VerificationStatus == "Rejected")
                                    { <span class="badge bg-danger">Rejected</span> }
                                    else
                                    { <span class="badge bg-warning text-dark">Pending</span> }
                                </td>
                                <td class="small text-danger">
                                    @if (!string.IsNullOrEmpty(doc.RejectReason)) { @doc.RejectReason }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a href="@doc.FilePath" target="_blank"
                                           class="btn btn-sm btn-outline-primary" title="View">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        @if (doc.VerificationStatus != "Approved")
                                        {
                                            <button class="btn btn-sm btn-outline-warning" title="Re-upload"
                                                    onclick="triggerReupload('@doc.DocumentType')">
                                                <i class="fa-solid fa-rotate-right"></i>
                                            </button>
                                            <form asp-action="Delete" asp-controller="CustomerKyc"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete this document?')">
                                                <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                                <button class="btn btn-sm btn-outline-danger" title="Delete">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>

@section Scripts {
<script>
    function showFileInput(val) {
        document.getElementById('fileSection').style.display = val ? 'block' : 'none';
        document.getElementById('submitSection').style.display = val ? 'block' : 'none';
    }
    function previewFile(input) {
        if (!input.files || !input.files[0]) return;
        const file = input.files[0];
        document.getElementById('previewSection').style.display = 'block';
        const imgEl = document.getElementById('imgPreview');
        const pdfEl = document.getElementById('pdfPreview');
        if (file.type.startsWith('image/')) {
            imgEl.style.display = 'block'; pdfEl.style.display = 'none';
            const reader = new FileReader();
            reader.onload = e => imgEl.src = e.target.result;
            reader.readAsDataURL(file);
        } else {
            imgEl.style.display = 'none'; pdfEl.style.display = 'block';
            document.getElementById('pdfName').textContent = file.name;
        }
    }
    function triggerReupload(docType) {
        const select = document.getElementById('docTypeSelect');
        select.value = docType;
        showFileInput(docType);
        document.getElementById('uploadForm').scrollIntoView({ behavior: 'smooth' });
    }
</script>
}
