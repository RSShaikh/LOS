@*
    Views/Shared/_LoanLayout.cshtml - Customer Layout
*@

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Loan Application — LOS Banking</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, Helvetica, sans-serif; background: #f4f5fb; }

        .sidebar {
            width: 260px;
            height: 100vh;
            background: linear-gradient(to bottom, #071b3b, #0d2a56);
            position: fixed;
            left: 0; top: 0;
            overflow-y: auto;
        }
        .sidebar .brand {
            color: #ffcc00;
            font-size: 18px;
            font-weight: bold;
            padding: 20px 20px 8px;
        }
        .sidebar .brand-sub {
            color: rgba(255,255,255,0.45);
            font-size: 11px;
            padding: 0 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 10px;
        }
        .sidebar a {
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            padding: 11px 22px;
            font-size: 14px;
            transition: 0.2s;
        }
        .sidebar a:hover {
            background: rgba(255,204,0,0.12);
            border-left: 3px solid #ffcc00;
            color: #ffcc00;
        }
        .sidebar i { width: 18px; text-align: center; font-size: 14px; }
        .sidebar .section-label {
            color: rgba(255,255,255,0.3);
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 14px 22px 4px;
        }
        .sidebar .logout-link {
            color: #ff6b6b !important;
            margin-top: 10px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .main-content { margin-left: 260px; padding: 25px; min-height: 100vh; }
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            background: white;
            padding: 12px 20px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        .top-bar .page-title { font-size: 17px; font-weight: 600; color: #071b3b; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="brand"><i class="fa-solid fa-building-columns me-2"></i>LOS Banking</div>
        <div class="brand-sub">Customer Portal</div>

        <div class="section-label">My Account</div>
        <a asp-controller="Customer" asp-action="Profile">
            <i class="fa-solid fa-user"></i> My Profile
        </a>
        <a asp-controller="Customer" asp-action="Kyc">
            <i class="fa-solid fa-id-card"></i> KYC Documents
        </a>

        <div class="section-label">Loan Process</div>
        <a asp-controller="Cibil" asp-action="Check">
            <i class="fa-solid fa-credit-card"></i> CIBIL Score
        </a>
        <a asp-controller="Cust" asp-action="MyEligibility">
            <i class="fa-solid fa-circle-check"></i> Eligibility Check
        </a>
        <a asp-controller="Loan" asp-action="Create">
            <i class="fa-solid fa-file-signature"></i> Apply for Loan
        </a>
        <a asp-controller="ApplicationStatus" asp-action="AIndex">
            <i class="fa-solid fa-chart-line"></i> Track Status
        </a>
        <a asp-controller="Cust" asp-action="MySanctionLetter">
            <i class="fa-solid fa-file-contract"></i> Sanction Letter
        </a>
        <a asp-controller="Cust" asp-action="MyDisbursement">
            <i class="fa-solid fa-money-check-dollar"></i> Disbursement
        </a>

        <a href="/Auth/Logout" class="logout-link">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
    </div>

    <div class="main-content">
        <div class="top-bar">
            <span class="page-title">@(ViewBag.PageTitle ?? "Dashboard")</span>
            <span class="user-info" style="font-size:14px; color:#666;">
                <i class="fa-solid fa-circle-user me-1 text-primary"></i>
                Welcome, <strong>@User.Identity?.Name</strong>
            </span>
        </div>
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
